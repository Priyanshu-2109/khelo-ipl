# MongoDB (required)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=khelo_ipl

# Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Public URL of this app (required for OAuth callback in production)
AUTH_URL=http://localhost:3000

# Google OAuth (optional). Also set NEXT_PUBLIC_GOOGLE_SIGNIN_ENABLED=true to show the button.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
NEXT_PUBLIC_GOOGLE_SIGNIN_ENABLED=false

# Session lifetime (seconds). Default: 7 days.
SESSION_MAX_AGE_SEC=604800
SESSION_UPDATE_AGE_SEC=86400

# First account with this email becomes admin (optional, signup or first Google login)
ADMIN_SEED_EMAIL=

# Password policy (optional overrides)
# PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_UPPERCASE=true
# PASSWORD_REQUIRE_LOWERCASE=true
# PASSWORD_REQUIRE_DIGIT=true
# PASSWORD_REQUIRE_SPECIAL=true
# BCRYPT_ROUNDS=12
